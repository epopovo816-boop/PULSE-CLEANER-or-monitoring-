    def speak(self, text):
        """Произнести текст голосом."""
        if not HAS_VOICE or not self.voice_enabled:
            return

        def _speak():
            with self.voice_lock:
                try:
                    engine = pyttsx3.init()
                    voices = engine.getProperty('voices')
                    for voice in voices:
                        if "ru" in voice.id.lower() or "russian" in voice.name.lower():
                            engine.setProperty('voice', voice.id)
                            break
                    engine.setProperty('rate', 150)
                    engine.setProperty('volume', 1.0)
                    engine.say(text)
                    engine.runAndWait()
                    engine.stop()
                except Exception:
                    pass

        threading.Thread(target=_speak, daemon=True).start()

    def voice_warning(self, warning_type):
        """Голосовое предупреждение с кулдауном."""
        now = time.time()
        if now - self.last_voice_time.get(warning_type, 0) < self.VOICE_COOLDOWN:
            return
        self.last_voice_time[warning_type] = now
        self.root.bell()
        msg = self.voice_messages.get(warning_type, "")
        if msg:
            self.speak(msg)

