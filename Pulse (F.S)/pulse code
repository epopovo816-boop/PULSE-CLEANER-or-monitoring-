    def _startup_load(self, tree):
        """Загрузить список элементов автозагрузки."""
        for item in tree.get_children():
            tree.delete(item)

        # Папка автозагрузки
        startup_folder = os.path.join(
            self.user_home, "AppData", "Roaming",
            "Microsoft", "Windows", "Start Menu", "Programs", "Startup"
        )

        if os.path.exists(startup_folder):
            for f in os.listdir(startup_folder):
                if f != "desktop.ini":
                    fp = os.path.join(startup_folder, f)
                    tree.insert("", "end", values=(f, fp, "📂 Папка автозагрузки"))

        # Реестр
        reg_keys = [
            ("HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run", "🔑 Реестр (пользователь)"),
            ("HKLM\\Software\\Microsoft\\Windows\\CurrentVersion\\Run", "🔑 Реестр (система)"),
            ("HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce", "🔑 Реестр RunOnce"),
        ]

        for reg_path, location in reg_keys:
            try:
                result = subprocess.run(
                    ["reg", "query", reg_path],
                    capture_output=True, text=True, timeout=5,
                    encoding="utf-8", errors="ignore"
                )
                if result.returncode == 0:
                    for line in result.stdout.strip().split("\n"):
                        line = line.strip()
                        if not line or line.startswith("HKEY"):
                            continue
                        for reg_type in ["REG_SZ", "REG_EXPAND_SZ", "REG_MULTI_SZ"]:
                            if reg_type in line:
                                parts = line.split(reg_type)
                                if len(parts) == 2:
                                    name = parts[0].strip()
                                    cmd = parts[1].strip()
                                    if name:
                                        tree.insert("", "end", values=(name, cmd, location))
                                break
            except Exception:
                pass

    def _startup_open_folder(self):
        """Открыть папку автозагрузки."""
        path = os.path.join(
            self.user_home, "AppData", "Roaming",
            "Microsoft", "Windows", "Start Menu", "Programs", "Startup"
        )
        try:
            os.startfile(path)
        except Exception as e:
            messagebox.showerror("Ошибка", str(e))

    def _startup_remove(self, tree):
        """Удалить выбранный элемент из автозагрузки."""
        sel = tree.selection()
        if not sel:
            messagebox.showwarning("Выберите элемент", "Выберите программу из списка.")
            return

        vals = tree.item(sel[0])['values']
        name = vals[0]
        cmd = vals[1]
        location = vals[2]

        if not messagebox.askyesno(
            "Подтверждение",
            f"Удалить «{name}» из автозагрузки?\n\n"
            f"Расположение: {location}\n\n"
            f"Программа не будет запускаться при входе в Windows."
        ):
            return

        try:
            if "Папка" in str(location):
                os.remove(cmd)
                tree.delete(sel[0])
                messagebox.showinfo("Готово", f"«{name}» удалён из автозагрузки.")

            elif "пользователь" in str(location).lower() or "RunOnce" in str(location):
                reg_path = "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run"
                if "RunOnce" in str(location):
                    reg_path = "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce"
                subprocess.run(
                    ["reg", "delete", reg_path, "/v", name, "/f"],
                    capture_output=True, timeout=5
                )
                tree.delete(sel[0])
                messagebox.showinfo("Готово", f"«{name}» удалён из реестра.")

            elif "система" in str(location).lower():
                reg_path = "HKLM\\Software\\Microsoft\\Windows\\CurrentVersion\\Run"
                subprocess.run(
                    ["reg", "delete", reg_path, "/v", name, "/f"],
                    capture_output=True, timeout=5
                )
                tree.delete(sel[0])
                messagebox.showinfo("Готово", f"«{name}» удалён из реестра системы.")

        except PermissionError:
            messagebox.showerror(
                "Ошибка доступа",
                "Нет прав для этой операции.\n"
                "Запустите Pulse от имени администратора."
            )
        except FileNotFoundError:
            tree.delete(sel[0])
            messagebox.showinfo("Готово", "Элемент уже был удалён.")
        except Exception as e:
            messagebox.showerror("Ошибка", str(e))    # =========================================
