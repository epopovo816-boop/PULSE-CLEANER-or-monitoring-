    def _scan_path(self, path, patterns=None):
        """Подсчитать размер файлов в папке."""
        total_size = 0
        total_count = 0

        if not path or not os.path.exists(path):
            return 0, 0

        try:
            if patterns:
                for pattern in patterns:
                    for fp in glob.glob(
                        os.path.join(path, "**", pattern), recursive=True
                    ):
                        try:
                            if os.path.isfile(fp):
                                total_size += os.path.getsize(fp)
                                total_count += 1
                        except (OSError, PermissionError):
                            pass
            else:
                for root, dirs, files in os.walk(path):
                    for f in files:
                        try:
                            fp = os.path.join(root, f)
                            total_size += os.path.getsize(fp)
                            total_count += 1
                        except (OSError, PermissionError):
                            pass
        except (OSError, PermissionError):
            pass

        return total_size, total_count

    def _delete_path(self, path, patterns=None):
        """Удалить файлы в папке."""
        deleted_size = 0
        deleted_count = 0
        error_count = 0

        if not path or not os.path.exists(path):
            return 0, 0, 0

        try:
            if patterns:
                for pattern in patterns:
                    for fp in glob.glob(
                        os.path.join(path, "**", pattern), recursive=True
                    ):
                        try:
                            if os.path.isfile(fp):
                                size = os.path.getsize(fp)
                                os.remove(fp)
                                deleted_size += size
                                deleted_count += 1
                        except (OSError, PermissionError):
                            error_count += 1
            else:
                for root, dirs, files in os.walk(path, topdown=False):
                    for f in files:
                        try:
                            fp = os.path.join(root, f)
                            size = os.path.getsize(fp)
                            os.remove(fp)
                            deleted_size += size
                            deleted_count += 1
                        except (OSError, PermissionError):
                            error_count += 1
                    for d in dirs:
                        try:
                            dp = os.path.join(root, d)
                            if not os.listdir(dp):
                                os.rmdir(dp)
                        except (OSError, PermissionError):
                            pass
        except (OSError, PermissionError):
            error_count += 1

        return deleted_size, deleted_count, error_count

    def _clean_start_scan(self):
        """Запустить сканирование."""
        if self.is_scanning:
            return

        self.is_scanning = True
        self.scan_results = {}
        self.clean_scan_btn.config(state="disabled", text="🔍 Сканирование...")
        self.clean_go_btn.config(state="disabled")
        self.clean_progress_bar["value"] = 0

        self._clean_log("Начало сканирования...", "info")

        def worker():
            total_size = 0
            cats = list(self.clean_cats.items())
            count = len(cats)

            for i, (key, cat) in enumerate(cats):
                progress = int((i / count) * 100)
                cat_size = 0

                self.root.after(0, lambda p=progress: (
                    self.clean_progress_bar.configure(value=p),
                    self.clean_progress_lbl.config(
                        text=f"Сканирование: {cat['name']}..."
                    )
                ))

                for path in cat["paths"]:
                    size, count_ = self._scan_path(path, cat.get("patterns"))
                    cat_size += size

                self.scan_results[key] = cat_size
                total_size += cat_size
                size_txt = self.fmt_size(cat_size)

                self.root.after(0, lambda k=key, s=cat_size, t=size_txt, n=cat["name"]: (
                    self.clean_size_labels[k].config(
                        text=t,
                        fg=self.c("green") if s > 0 else self.c("muted")
                    ),
                    self._clean_log(
                        f"{n}: {t}", "ok" if s > 0 else "info"
                    )
                ))

            total_txt = self.fmt_size(total_size)
            self.root.after(0, lambda: (
                self.clean_total_lbl.config(
                    text=f"💾 Можно освободить: {total_txt}"
                ),
                self.clean_progress_lbl.config(text="Сканирование завершено ✅"),
                self.clean_progress_bar.configure(value=100),
                self.clean_scan_btn.config(state="normal", text="🔍  Сканировать"),
                self.clean_go_btn.config(state="normal"),
                self._clean_log(f"Итого: {total_txt}", "ok")
            ))
            self.is_scanning = False

        threading.Thread(target=worker, daemon=True).start()

    def _clean_start_clean(self):
        """Запустить очистку."""
        if self.is_cleaning:
            return

        selected = [
            key for key, cat in self.clean_cats.items()
            if cat["enabled"].get() and self.scan_results.get(key, 0) > 0
        ]

        if not selected:
            messagebox.showinfo(
                "Нечего чистить",
                "Нет файлов для очистки.\nСначала выполните сканирование."
            )
            return

        total = sum(self.scan_results.get(k, 0) for k in selected)

        if not messagebox.askyesno(
            "Подтверждение очистки",
            f"Будет удалено примерно: {self.fmt_size(total)}\n"
            f"Категорий: {len(selected)}\n\n"
            f"Удаляются ТОЛЬКО временные файлы и кэш.\n"
            f"Системные файлы Windows НЕ затрагиваются.\n\n"
            f"Продолжить?"
        ):
            return

        self.is_cleaning = True
        self.clean_go_btn.config(state="disabled", text="🧹 Очистка...")
        self.clean_scan_btn.config(state="disabled")
        self.clean_progress_bar["value"] = 0

        self._clean_log("Начало очистки...", "info")

        def worker():
            total_deleted = 0
            count = len(selected)

            for i, key in enumerate(selected):
                cat = self.clean_cats[key]
                progress = int((i / count) * 100)
                cat_deleted = 0
                cat_errors = 0

                self.root.after(0, lambda p=progress: (
                    self.clean_progress_bar.configure(value=p),
                    self.clean_progress_lbl.config(
                        text=f"Очистка: {cat['name']}..."
                    )
                ))

                for path in cat["paths"]:
                    s, d, e = self._delete_path(path, cat.get("patterns"))
                    cat_deleted += s
                    cat_errors += e

                total_deleted += cat_deleted
                size_txt = self.fmt_size(cat_deleted)

                self.root.after(0, lambda k=key, s=size_txt, e=cat_errors, n=cat["name"]: (
                    self.clean_size_labels[k].config(text="✅", fg=self.c("green")),
                    self._clean_log(
                        f"✅ {n}: удалено {s}" +
                        (f" ({e} пропущено)" if e > 0 else ""), "ok"
                    )
                ))

            total_txt = self.fmt_size(total_deleted)
            self.root.after(0, lambda: (
                self.clean_total_lbl.config(text=f"✅ Освобождено: {total_txt}"),
                self.clean_progress_lbl.config(text="Очистка завершена ✅"),
                self.clean_progress_bar.configure(value=100),
                self.clean_go_btn.config(state="normal", text="🧹  Очистить выбранное"),
                self.clean_scan_btn.config(state="normal"),
                self._clean_log(f"Готово! Освобождено: {total_txt}", "ok")
            ))
            self.is_cleaning = False

        threading.Thread(target=worker, daemon=True).start()

