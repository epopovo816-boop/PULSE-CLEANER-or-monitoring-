    def show_tab(self, tab_id):
        """Переключить вкладку."""
        # Остановить монитор если уходим
        if self.current_tab == "monitor" and tab_id != "monitor":
            self.monitor_active = False

        self.current_tab = tab_id

        # Подсветка активной кнопки
        for tid, btn in self.tab_buttons.items():
            if tid == tab_id:
                btn.config(bg=self.c("sidebar_hover"), fg=self.c("accent"))
            else:
                btn.config(bg=self.c("sidebar"), fg=self.c("fg"))

        # Очистка контента
        for widget in self.content.winfo_children():
            widget.destroy()

        # Отрисовка вкладки
        builders = {
            "monitor": self.build_monitor_tab,
            "cleaner": self.build_cleaner_tab,
            "disk": self.build_disk_tab,
            "startup": self.build_startup_tab,
            "tools": self.build_tools_tab,
            "handbook": self.build_handbook_tab,
        }
        builder = builders.get(tab_id)
        if builder:
            builder()

    def toggle_theme(self):
        """Переключить тему."""
        self.monitor_active = False
        self.current_theme = "light" if self.current_theme == "dark" else "dark"

        for widget in self.root.winfo_children():
            widget.destroy()

        self.root.configure(bg=self.c("bg"))
        self.build_shell()
        self.show_tab(self.current_tab or "monitor")

