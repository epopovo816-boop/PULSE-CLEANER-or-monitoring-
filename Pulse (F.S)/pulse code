    def c(self, key):
        """Получить цвет из текущей темы."""
        return self.themes[self.current_theme].get(key, "#ffffff")

    def fmt_size(self, size_bytes):
        """Форматировать размер файла."""
        if size_bytes < 0:
            size_bytes = 0
        if size_bytes < 1024:
            return f"{size_bytes} Б"
        elif size_bytes < 1024 ** 2:
            return f"{size_bytes / 1024:.1f} КБ"
        elif size_bytes < 1024 ** 3:
            return f"{size_bytes / 1024 ** 2:.1f} МБ"
        else:
            return f"{size_bytes / 1024 ** 3:.2f} ГБ"

    def bar_color(self, value, limit):
        """Цвет прогресс-бара по значению."""
        if value > limit:
            return self.c("red")
        elif value > limit * 0.75:
            return self.c("orange")
        return self.c("green")

