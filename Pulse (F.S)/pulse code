    def _tools_run_cmd(self, cmd, title):
        """Запустить команду в отдельном окне cmd."""
        if messagebox.askyesno(
            f"Запустить: {title}",
            f"Выполнить команду:\n\n{cmd}\n\n"
            f"Откроется окно командной строки."
        ):
            try:
                subprocess.Popen(
                    f'start cmd /k "{cmd}"',
                    shell=True
                )
            except Exception as e:
                messagebox.showerror("Ошибка", str(e))

    def _tools_open_util(self, cmd, name):
        """Открыть утилиту Windows."""
        try:
            if cmd.endswith(".msc") or cmd.endswith(".cpl"):
                os.system(f"start {cmd}")
            else:
                subprocess.Popen(cmd, shell=True)
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось открыть {name}:\n{e}")

    def _tools_quick_cmd(self, cmd, name):
        """Выполнить быструю команду."""
        if messagebox.askyesno("Подтверждение", f"Выполнить:\n{name}?"):
            try:
                subprocess.Popen(cmd, shell=True)
            except Exception as e:
                messagebox.showerror("Ошибка", str(e))

    def _tools_set_dns(self, primary, secondary, name):
        """Сменить DNS."""
        if primary is None:
            if messagebox.askyesno("DNS", "Сбросить DNS на автоматический (от провайдера)?"):
                try:
                    for iface in ["Ethernet", "Wi-Fi", "Беспроводная сеть"]:
                        subprocess.run(
                            ["netsh", "interface", "ip", "set", "dns",
                             f"name={iface}", "source=dhcp"],
                            capture_output=True, timeout=5
                        )
                    subprocess.run(
                        ["ipconfig", "/flushdns"],
                        capture_output=True, timeout=5
                    )
                    messagebox.showinfo("DNS", "DNS сброшен на автоматический ✅")
                except Exception as e:
                    messagebox.showerror("Ошибка", str(e))
            return

        clean_name = name.replace("\n", " ").strip()
        if not messagebox.askyesno(
            "Смена DNS",
            f"Сменить DNS на {clean_name}?\n\n"
            f"Основной: {primary}\n"
            f"Резервный: {secondary}\n\n"
            f"Для применения может потребоваться\n"
            f"запуск от имени администратора."
        ):
            return

        try:
            for iface in ["Ethernet", "Wi-Fi", "Беспроводная сеть"]:
                subprocess.run(
                    ["netsh", "interface", "ip", "set", "dns",
                     f"name={iface}", "static", primary],
                    capture_output=True, timeout=5
                )
                if secondary:
                    subprocess.run(
                        ["netsh", "interface", "ip", "add", "dns",
                         f"name={iface}", secondary, "index=2"],
                        capture_output=True, timeout=5
                    )

            subprocess.run(
                ["ipconfig", "/flushdns"],
                capture_output=True, timeout=5
            )
            messagebox.showinfo(
                "DNS изменён ✅",
                f"DNS успешно изменён на {clean_name}\n"
                f"Основной: {primary}\n"
                f"Резервный: {secondary}"
            )
        except Exception as e:
            messagebox.showerror(
                "Ошибка",
                f"Не удалось сменить DNS:\n{e}\n\n"
                f"Попробуйте запустить Pulse\nот имени администратора."
            )

