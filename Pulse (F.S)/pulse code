    def _hb_render(self, entries):
        """Отрисовать записи справочника."""
        for w in self.hb_inner.winfo_children():
            w.destroy()

        if not entries:
            tk.Label(
                self.hb_inner,
                text="😔 Ничего не найдено\n\nПопробуйте другой запрос",
                font=("Arial", 14),
                bg=self.c("bg"), fg=self.c("muted"),
                justify="center"
            ).pack(pady=50)
            return

        # Группировка по категориям
        cats = {}
        for e in entries:
            cat = e["cat"]
            if cat not in cats:
                cats[cat] = []
            cats[cat].append(e)

        cat_icons = {
            "BSOD": "💀", "Windows": "🪟", "Сеть": "🌐",
            "Железо": "🔧", "Команды": "⌨", "Советы": "💡"
        }

        sev_colors = {
            "critical": self.c("red"),
            "warning": self.c("orange"),
            "info": self.c("accent")
        }

        sev_labels = {
            "critical": "🔴 КРИТИЧНО",
            "warning": "🟠 ВНИМАНИЕ",
            "info": "🔵 ИНФОРМАЦИЯ"
        }

        for cat_name, items in cats.items():
            icon = cat_icons.get(cat_name, "📋")

            # Заголовок категории
            tk.Label(
                self.hb_inner,
                text=f"{icon}  {cat_name}",
                font=("Arial", 15, "bold"),
                bg=self.c("bg"), fg=self.c("accent"),
                anchor="w"
            ).pack(fill="x", padx=5, pady=(15, 5))

            for item in items:
                border_color = sev_colors.get(item["sev"], self.c("accent"))

                # Карточка с цветной рамкой
                outer = tk.Frame(self.hb_inner, bg=border_color)
                outer.pack(fill="x", padx=5, pady=3)

                card = tk.Frame(outer, bg=self.c("card"))
                card.pack(fill="x", padx=2, pady=2)

                # Заголовок карточки
                card_header = tk.Frame(card, bg=self.c("card"))
                card_header.pack(fill="x", padx=15, pady=(10, 3))

                tk.Label(
                    card_header,
                    text=item["name"],
                    font=("Arial", 12, "bold"),
                    bg=self.c("card"), fg=self.c("fg"),
                    anchor="w"
                ).pack(side="left")

                tk.Label(
                    card_header,
                    text=f"[ {item['code']} ]",
                    font=("Consolas", 10),
                    bg=self.c("card"), fg=self.c("muted")
                ).pack(side="left", padx=10)

                tk.Label(
                    card_header,
                    text=sev_labels.get(item["sev"], ""),
                    font=("Arial", 9, "bold"),
                    bg=self.c("card"),
                    fg=border_color
                ).pack(side="right")

                # Описание
                tk.Label(
                    card, text=item["desc"],
                    font=("Arial", 10),
                    bg=self.c("card"), fg=self.c("fg"),
                    anchor="w", justify="left",
                    wraplength=1000, padx=15, pady=3
                ).pack(fill="x")

                # Причины и решения
                two_cols = tk.Frame(card, bg=self.c("card"))
                two_cols.pack(fill="x", padx=15, pady=(3, 10))

                # Причины
                left_col = tk.Frame(two_cols, bg=self.c("card2"))
                left_col.pack(side="left", fill="both", expand=True, padx=(0, 5))

                tk.Label(
                    left_col, text="❓ Причины:",
                    font=("Arial", 10, "bold"),
                    bg=self.c("card2"), fg=self.c("orange"),
                    anchor="w", padx=10, pady=5
                ).pack(fill="x")

                for cause in item["causes"].split("|"):
                    tk.Label(
                        left_col,
                        text=f"  • {cause.strip()}",
                        font=("Arial", 9),
                        bg=self.c("card2"), fg=self.c("fg"),
                        anchor="w", justify="left",
                        wraplength=430, padx=10, pady=1
                    ).pack(fill="x")

                tk.Frame(left_col, bg=self.c("card2"), height=6).pack()

                # Решения
                right_col = tk.Frame(two_cols, bg=self.c("card2"))
                right_col.pack(side="right", fill="both", expand=True, padx=(5, 0))

                tk.Label(
                    right_col, text="✅ Решения:",
                    font=("Arial", 10, "bold"),
                    bg=self.c("card2"), fg=self.c("green"),
                    anchor="w", padx=10, pady=5
                ).pack(fill="x")

                for i, fix in enumerate(item["fix"].split("|"), 1):
                    tk.Label(
                        right_col,
                        text=f"  {i}. {fix.strip()}",
                        font=("Arial", 9),
                        bg=self.c("card2"), fg=self.c("fg"),
                        anchor="w", justify="left",
                        wraplength=430, padx=10, pady=1
                    ).pack(fill="x")

                tk.Frame(right_col, bg=self.c("card2"), height=6).pack()

    def _hb_on_search(self, *args):
        """Обработка поиска в справочнике."""
        query = self.hb_query.get().strip().lower()

        if len(query) < 2:
            self._hb_render(self.hb_data)
            self.hb_count_lbl.config(text="")
            return

        results = []
        for item in self.hb_data:
            searchable = " ".join([
                item["name"], item["code"], item["cat"],
                item["desc"], item["causes"], item["fix"]
            ]).lower()

            if query in searchable:
                results.append(item)

        self._hb_render(results)
        self.hb_count_lbl.config(text=f"Найдено: {len(results)}")


