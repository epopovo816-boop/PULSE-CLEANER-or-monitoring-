    def _disk_find_big_files(self, container):
        """Найти большие файлы на рабочем столе и в загрузках."""
        for w in container.winfo_children():
            w.destroy()

        search_dirs = [
            os.path.join(self.user_home, "Downloads"),
            os.path.join(self.user_home, "Desktop"),
            os.path.join(self.user_home, "OneDrive", "Desktop")
        ]

        files = []
        for folder in search_dirs:
            if os.path.exists(folder):
                try:
                    for f in os.listdir(folder):
                        fp = os.path.join(folder, f)
                        if os.path.isfile(fp):
                            try:
                                size = os.path.getsize(fp)
                                files.append((fp, size))
                            except (OSError, PermissionError):
                                pass
                except (OSError, PermissionError):
                    pass

        files.sort(key=lambda x: x[1], reverse=True)

        if not files:
            tk.Label(
                container, text="😊 Больших файлов не найдено!",
                font=("Arial", 12), bg=self.c("bg"), fg=self.c("muted")
            ).pack(pady=20)
            return

        # Заголовок таблицы
        header = tk.Frame(container, bg=self.c("card2"))
        header.pack(fill="x", pady=(0, 2))

        tk.Label(
            header, text="Файл", font=("Arial", 10, "bold"),
            bg=self.c("card2"), fg=self.c("fg"),
            anchor="w", padx=10, pady=5
        ).pack(side="left", fill="x", expand=True)

        tk.Label(
            header, text="Размер", font=("Arial", 10, "bold"),
            bg=self.c("card2"), fg=self.c("fg"),
            padx=15, pady=5, width=12
        ).pack(side="right")

        for fp, size in files[:25]:
            name = os.path.basename(fp)
            if len(name) > 45:
                name = name[:42] + "..."

            color = self.c("red") if size > 500 * 1024 * 1024 else \
                    self.c("orange") if size > 100 * 1024 * 1024 else \
                    self.c("fg")

            row = tk.Frame(container, bg=self.c("card"))
            row.pack(fill="x", pady=1)

            tk.Label(
                row, text=name,
                font=("Consolas", 9),
                bg=self.c("card"), fg=self.c("fg"),
                anchor="w", padx=10, pady=4
            ).pack(side="left", fill="x", expand=True)

            tk.Label(
                row, text=self.fmt_size(size),
                font=("Arial", 9, "bold"),
                bg=self.c("card"), fg=color,
                padx=15, width=12
            ).pack(side="right")

