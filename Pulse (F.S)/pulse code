    def _make_bar(self, parent, name):
        """Создать прогресс-бар."""
        frame = tk.Frame(parent, bg=self.c("bg"))
        frame.pack(fill="x", padx=15, pady=3)

        tk.Label(
            frame, text=name, font=("Arial", 10, "bold"),
            bg=self.c("bg"), fg=self.c("fg"), width=5, anchor="w"
        ).pack(side="left")

        style = ttk.Style()
        style_name = f"pulse_{name}.Horizontal.TProgressbar"
        style.configure(
            style_name,
            troughcolor=self.c("card"),
            background=self.c("green"),
            thickness=18
        )

        bar = ttk.Progressbar(frame, mode="determinate", style=style_name)
        bar.pack(side="left", fill="x", expand=True, padx=5)

        val_label = tk.Label(
            frame, text="0%", font=("Arial", 10, "bold"),
            bg=self.c("bg"), fg=self.c("fg"), width=7
        )
        val_label.pack(side="right")

        return bar, val_label

    def _update_monitor(self):
        """Обновление данных монитора каждые 2 сек."""
        if not self.monitor_active:
            return

        try:
            # CPU
            cpu = psutil.cpu_percent(interval=0)
            self.mon_cpu_bar["value"] = cpu
            self.mon_cpu_val.config(text=f"{cpu:.1f}%")
            ttk.Style().configure(
                "pulse_CPU.Horizontal.TProgressbar",
                background=self.bar_color(cpu, self.CPU_LIMIT)
            )
            if cpu > self.CPU_LIMIT:
                self.voice_warning("cpu")

            # RAM
            ram = psutil.virtual_memory()
            self.mon_ram_bar["value"] = ram.percent
            self.mon_ram_val.config(text=f"{ram.percent:.1f}%")
            ttk.Style().configure(
                "pulse_RAM.Horizontal.TProgressbar",
                background=self.bar_color(ram.percent, self.RAM_LIMIT)
            )
            if ram.percent > self.RAM_LIMIT:
                self.voice_warning("ram")

            # Диск
            disk = psutil.disk_usage("/")
            self.mon_disk_bar["value"] = disk.percent
            self.mon_disk_val.config(text=f"{disk.percent:.1f}%")
            ttk.Style().configure(
                "pulse_Диск.Horizontal.TProgressbar",
                background=self.bar_color(disk.percent, self.DISK_LIMIT)
            )
            if disk.percent > self.DISK_LIMIT:
                self.voice_warning("disk")

            # GPU
            gpu_load = 0
            if HAS_GPU:
                try:
                    gpus = GPUtil.getGPUs()
                    if gpus:
                        gpu_load = gpus[0].load * 100
                except Exception:
                    pass

            self.mon_gpu_bar["value"] = gpu_load
            self.mon_gpu_val.config(
                text=f"{gpu_load:.1f}%" if HAS_GPU else "N/A"
            )
            ttk.Style().configure(
                "pulse_GPU.Horizontal.TProgressbar",
                background=self.bar_color(gpu_load, self.GPU_LIMIT)
            )
            if gpu_load > self.GPU_LIMIT:
                self.voice_warning("gpu")

            # Сеть
            net = psutil.net_io_counters()
            now = time.time()
            elapsed = max(now - self.prev_net_time, 0.1)

            down = max(0, (net.bytes_recv - self.prev_net.bytes_recv) / elapsed / 1024)
            up = max(0, (net.bytes_sent - self.prev_net.bytes_sent) / elapsed / 1024)

            self.prev_net = net
            self.prev_net_time = now

            d_txt = f"{down / 1024:.1f} МБ/с" if down > 1024 else f"{down:.1f} КБ/с"
            u_txt = f"{up / 1024:.1f} МБ/с" if up > 1024 else f"{up:.1f} КБ/с"
            self.mon_net_label.config(text=f"⬇ {d_txt}  |  ⬆ {u_txt}")

            # Статус
            warnings = []
            if cpu > self.CPU_LIMIT:
                warnings.append("CPU")
            if ram.percent > self.RAM_LIMIT:
                warnings.append("RAM")
            if disk.percent > self.DISK_LIMIT:
                warnings.append("Диск")
            if gpu_load > self.GPU_LIMIT:
                warnings.append("GPU")

            if warnings:
                self.mon_status.config(
                    text=f"⚠ НАГРУЗКА: {', '.join(warnings)}",
                    fg=self.c("red")
                )
            else:
                self.mon_status.config(
                    text="Статус: Всё в норме ✅",
                    fg=self.c("green")
                )

            # История
            self.cpu_history.append(cpu)
            self.ram_history.append(ram.percent)
            self.net_down_history.append(down)
            self.net_up_history.append(up)

            # Графики
            if HAS_MATPLOTLIB:
                try:
                    self.mon_ax1.clear()
                    self.mon_ax1.set_facecolor(self.c("graph_bg"))
                    self.mon_ax1.plot(
                        list(self.cpu_history),
                        color=self.c("line1"), lw=1.5, label="CPU"
                    )
                    self.mon_ax1.plot(
                        list(self.ram_history),
                        color=self.c("line2"), lw=1.5, label="RAM"
                    )
                    self.mon_ax1.set_ylim(0, 100)
                    self.mon_ax1.set_title("CPU / RAM", color=self.c("fg"), fontsize=10)
                    self.mon_ax1.axhline(
                        y=self.CPU_LIMIT, color=self.c("red"),
                        ls="--", alpha=0.5, lw=1
                    )
                    self.mon_ax1.legend(
                        loc="upper left", fontsize=7,
                        facecolor=self.c("card"),
                        labelcolor=self.c("fg")
                    )
                    self.mon_ax1.tick_params(colors=self.c("muted"))

                    self.mon_ax2.clear()
                    self.mon_ax2.set_facecolor(self.c("graph_bg"))
                    self.mon_ax2.plot(
                        list(self.net_down_history),
                        color=self.c("line3"), lw=1.5, label="⬇"
                    )
                    self.mon_ax2.plot(
                        list(self.net_up_history),
                        color=self.c("line4"), lw=1.5, label="⬆"
                    )
                    self.mon_ax2.set_title("Сеть КБ/с", color=self.c("fg"), fontsize=10)
                    self.mon_ax2.legend(
                        loc="upper left", fontsize=7,
                        facecolor=self.c("card"),
                        labelcolor=self.c("fg")
                    )
                    self.mon_ax2.tick_params(colors=self.c("muted"))

                    self.mon_fig.patch.set_facecolor(self.c("graph_bg"))
                    self.mon_fig.tight_layout()
                    self.mon_canvas.draw()
                except Exception:
                    pass

            # Процессы
            for item in self.mon_tree.get_children():
                self.mon_tree.delete(item)

            procs = []
            for p in psutil.process_iter(['pid', 'name', 'cpu_percent', 'memory_info']):
                try:
                    info = p.info
                    ram_mb = info['memory_info'].rss / 1024 / 1024 if info['memory_info'] else 0
                    procs.append({
                        'name': info['name'] or "???",
                        'pid': info['pid'],
                        'cpu': info['cpu_percent'] or 0,
                        'ram': ram_mb
                    })
                except (psutil.NoSuchProcess, psutil.AccessDenied):
                    pass

            sort_key = 'cpu' if self.mon_sort.get() == "cpu" else 'ram'
            procs.sort(key=lambda x: x[sort_key], reverse=True)

            for proc in procs[:15]:
                name = proc['name'][:28]
                self.mon_tree.insert("", "end", values=(
                    name, proc['pid'],
                    f"{proc['cpu']:.1f}", f"{proc['ram']:.1f}"
                ))

        except Exception:
            pass

        if self.monitor_active:
            self.root.after(2000, self._update_monitor)

    def mon_kill_process(self):
        """Завершить выбранный процесс."""
        sel = self.mon_tree.selection()
        if not sel:
            messagebox.showwarning("Выберите процесс", "Сначала выберите процесс в таблице.")
            return

        vals = self.mon_tree.item(sel[0])['values']
        pid = int(vals[1])
        name = vals[0]

        if messagebox.askyesno(
            "Подтверждение",
            f"Завершить процесс «{name}» (PID: {pid})?\n\nЭто может привести к потере данных!"
        ):
            try:
                psutil.Process(pid).terminate()
                messagebox.showinfo("Готово", f"Процесс «{name}» завершён.")
            except psutil.AccessDenied:
                messagebox.showerror("Ошибка", "Нет прав. Запустите Pulse от имени администратора.")
            except psutil.NoSuchProcess:
                messagebox.showinfo("Ошибка", "Процесс уже завершён.")
            except Exception as e:
                messagebox.showerror("Ошибка", str(e))    # =========================================
